---
// about.astro — upgraded April 2026
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { contact } from '../data/contact.js';
import { testimonials } from '../data/testimonials.js';

const pageTitle = "About EWaste Kochi — Kerala's KSPCB-Authorized ITAD & E-Waste Recycling Company";
const pageDesc = "Learn about EWaste Kochi — founded 2018 in Thrippunithura. KSPCB Auth. No. KL/EW/628. NIST 800-88 certified. 500+ corporate clients, 50,000+ devices processed, zero data breaches. Kerala's most trusted ITAD and e-waste recycling company.";

const stats = [
  { n: '2018', l: 'Founded' },
  { n: '500+', l: 'Corporate Clients' },
  { n: '50K+', l: 'Devices Processed' },
  { n: '4.9★', l: '127+ Reviews' },
  { n: '98.2%', l: 'Landfill Diversion' },
  { n: '0', l: 'Data Breaches' },
];

const certs = [
  { label: 'KSPCB E-Waste Authorization', value: 'No. KL/EW/628', color: 'var(--green)' },
  { label: 'EPR Registration (CPCB)', value: 'Central Pollution Control Board', color: 'var(--blue)' },
  { label: 'Data Destruction Standard', value: 'NIST SP 800-88 R1 Certified Process', color: 'var(--amber)' },
  { label: 'DoD Data Wiping', value: 'DoD 5220.22-M Compliant', color: 'var(--amber)' },
  { label: 'DPDP Act 2023', value: 'Full Compliance Documentation', color: 'var(--green)' },
  { label: 'ISO Alignment', value: 'ISO 14001:2015 Environmental Mgmt', color: 'var(--blue)' },
];

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'About Us', url: 'https://ewastekochi.com/about/' },
];
---

<BaseLayout title={pageTitle} description={pageDesc} breadcrumbs={breadcrumbs}>
  <Navbar currentPath="/about/" />
  <main>

    <section style="padding:80px 0 60px;background:var(--bg)">
      <div class="wrap">
        <nav aria-label="Breadcrumb" style="font-size:.8rem;color:var(--muted);margin-bottom:20px">
          <a href="/" style="color:var(--green)">Home</a> › About Us
        </nav>
        <div class="badge badge-g" style="margin-bottom:16px">🏭 Founded 2018 · Thrippunithura, Kochi</div>
        <h1 style="font-size:clamp(2rem,5vw,3.8rem);line-height:1.05;margin-bottom:18px;font-weight:800;letter-spacing:-.03em">
          About <span style="color:var(--green)">EWaste Kochi</span><br/>Kerala's Certified ITAD &<br/>E-Waste Recycling Authority
        </h1>
        <p style="font-size:1rem;color:var(--text);max-width:640px;line-height:1.7;margin-bottom:35px;font-family:var(--serif);font-style:italic">
          We built EWaste Kochi because Kerala's rapidly growing IT sector had no safe, certified, local ITAD partner. Since 2018, we've processed 50,000+ devices for 500+ clients across Kochi and Kerala — with zero data breaches and 98.2% landfill diversion.
        </p>
      </div>
    </section>

    <!-- STATS -->
    <section class="section-alt">
      <div class="wrap">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:15px">
          {stats.map(s => (
            <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:22px;text-align:center">
              <div style="font-size:1.8rem;font-weight:800;color:var(--green);letter-spacing:-.04em">{s.n}</div>
              <div style="font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-top:4px">{s.l}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- OUR STORY + CERTS -->
    <section class="section">
      <div class="wrap">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px">
          <div>
            <div class="sec-eyebrow">Our Story</div>
            <h2 class="sec-title" style="margin-bottom:20px">Built for <em>Kerala's</em> ITAD Gap</h2>
            <div style="font-family:var(--serif);font-size:.95rem;color:var(--text);line-height:1.85;display:flex;flex-direction:column;gap:14px">
              <p>EWaste Kochi was founded in 2018 in Thrippunithura, Kochi by a team with backgrounds in IT services, environmental compliance and waste management. The founding insight was specific: Kochi's IT sector — particularly the hundreds of companies in Infopark and Kakkanad — had no local certified ITAD partner.</p>
              <p>Companies were either shipping e-waste to facilities in other states (expensive, risky for chain-of-custody) or using informal recyclers (illegal and data-risk laden). We obtained KSPCB authorization, invested in industrial data destruction equipment, and built the chain-of-custody systems needed for corporate ITAD.</p>
              <p>Today we serve 500+ clients from individual households to Fortune 500 multinationals with offices in Kochi. Our zero data breach record across 50,000+ devices processed remains our proudest achievement.</p>
            </div>
          </div>
          <div>
            <div class="sec-eyebrow">Certifications & Compliance</div>
            <h2 class="sec-title" style="margin-bottom:20px">Verified <em>Credentials</em></h2>
            <div style="display:flex;flex-direction:column;gap:12px">
              {certs.map(c => (
                <div style={`background:var(--card);border-left:3px solid ${c.color};border-radius:0 10px 10px 0;padding:14px 18px`}>
                  <div style="font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px">{c.label}</div>
                  <div style={`font-size:.88rem;font-weight:600;color:${c.color}`}>{c.value}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="section-alt">
      <div class="wrap">
        <div class="sec-eyebrow">What Our Clients Say</div>
        <h2 class="sec-title" style="margin-bottom:2rem">4.9★ Across <em>127+ Reviews</em></h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px">
          {testimonials.slice(0,3).map(t => (
            <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:24px">
              <div style="color:var(--amber);font-size:1.1rem;letter-spacing:2px;margin-bottom:12px">{'★'.repeat(t.rating)}</div>
              <p style="font-size:.87rem;color:var(--text);line-height:1.75;margin-bottom:16px;font-family:var(--serif);font-style:italic">"{t.text}"</p>
              <div>
                <div style="font-size:.82rem;font-weight:700;color:var(--white)">{t.name} · {t.role}</div>
                <div style="font-size:.75rem;color:var(--muted)">{t.company}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section">
      <div class="wrap" style="text-align:center">
        <h2 class="sec-title">Ready to Work With <em>Kerala's Best?</em></h2>
        <p class="sec-sub" style="margin:0 auto 30px">Free quote in 15 minutes. KSPCB authorized. Zero data breach guarantee.</p>
        <div style="display:flex;gap:15px;justify-content:center;flex-wrap:wrap">
          <a href={contact.whatsappMessage} target="_blank" rel="noopener" class="btn btn-wa btn-lg">💬 WhatsApp Us</a>
          <a href="/contact/" class="btn btn-primary btn-lg">Book Pickup →</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
