---
// src/components/RelatedPosts.astro — Internal linking engine
// Picks 3 related posts from the same cluster (deterministic, no randomness)
import pillarsData from '../data/pillars.json';

interface Props {
  currentSlug: string;
  pillarSlug: string;
  clusterSlug: string;
}

const { currentSlug, pillarSlug, clusterSlug } = Astro.props;
const BASE = 'https://ewastekochi.com';

function slugify(str: string) {
  return str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

const pillar = pillarsData.find((p) => p.slug === pillarSlug);
const cluster = pillar?.clusters.find((c) => c.id === clusterSlug);

// Generate 3 related posts from same cluster (different post numbers)
const related = cluster
  ? [2, 5, 9].map((n) => ({
      slug: slugify(`${cluster.keyword}-${n}`),
      title: `${cluster.name}: Deep Dive ${n} — ${pillar?.name}`,
      excerpt: `Comprehensive guide to ${cluster.keyword} — covering compliance, process, and best practices for Kerala businesses.`,
    }))
  : [];

// Filter out current post
const filtered = related.filter((r) => r.slug !== currentSlug).slice(0, 3);
---

{filtered.length > 0 && (
  <aside class="related-posts" aria-label="Related articles">
    <h2 class="related-heading">Related Articles</h2>
    <div class="related-grid">
      {filtered.map((post) => (
        <a href={`/${pillarSlug}/${clusterSlug}/${post.slug}/`} class="related-card">
          <span class="related-eyebrow">{pillar?.icon} {cluster?.name}</span>
          <h3 class="related-title">{post.title}</h3>
          <p class="related-excerpt">{post.excerpt}</p>
          <span class="related-link">Read article →</span>
        </a>
      ))}
    </div>
  </aside>
)}

<style>
.related-posts { margin-top: 48px; padding-top: 40px; border-top: 1px solid var(--border); }
.related-heading { font-size: 1.1rem; color: var(--white); margin-bottom: 1.5rem; }
.related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
.related-card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 22px; display: flex; flex-direction: column; gap: 8px; text-decoration: none; transition: all .2s; }
.related-card:hover { border-color: rgba(0,232,150,.3); transform: translateY(-2px); }
.related-eyebrow { font-size: .68rem; color: var(--green); font-weight: 700; letter-spacing: .1em; text-transform: uppercase; }
.related-title { font-size: .9rem; font-weight: 700; color: var(--white); line-height: 1.3; margin: 0; }
.related-excerpt { font-size: .78rem; color: var(--muted); line-height: 1.6; margin: 0; }
.related-link { font-size: .78rem; color: var(--green); margin-top: auto; }
</style>
