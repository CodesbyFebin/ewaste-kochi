---
// src/components/RelatedQuestions.astro
import faqsData from '../data/faqDatabase.json';

interface Props {
  pillarSlug?: string;
  clusterSlug?: string;
  limit?: number;
}

const { pillarSlug, clusterSlug, limit = 5 } = Astro.props;

// Filter FAQs based on cluster or pillar tags
const relatedFaqs = faqsData
  .filter(faq => {
    if (clusterSlug && faq.tags.includes(clusterSlug)) return true;
    if (pillarSlug && faq.tags.includes(pillarSlug)) return true;
    return false;
  })
  .slice(0, limit);

// Fallback to general FAQs if not enough matches found
const displayFaqs = relatedFaqs.length >= 3 
  ? relatedFaqs 
  : [...relatedFaqs, ...faqsData.filter(f => f.tags.includes('general')).slice(0, limit - relatedFaqs.length)];
---

{displayFaqs.length > 0 && (
  <section class="related-questions section-alt">
    <div class="wrap">
      <div class="text-center">
        <span class="sec-eyebrow">💡 Related Questions</span>
        <h2 class="sec-title">Deeper Insights you might need</h2>
      </div>
      <div class="faq-accordion">
        {displayFaqs.map((faq) => (
          <details class="faq-details">
            <summary class="faq-summary">
              <span>{faq.question}</span>
              <span class="faq-icon">+</span>
            </summary>
            <div class="faq-answer">
              <p set:html={faq.answer}></p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

<style>
.related-questions { padding: 60px 0; border-top: 1px solid var(--border); }
.faq-accordion { max-width: 820px; margin: 2rem auto 0; display: flex; flex-direction: column; gap: 12px; }
.faq-details { background: var(--card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.faq-summary { display: flex; align-items: center; justify-content: space-between; padding: 18px 24px; cursor: pointer; list-style: none; font-weight: 600; font-size: 0.95rem; }
.faq-summary::-webkit-details-marker { display: none; }
.faq-icon { color: var(--green); font-size: 1.2rem; }
.faq-answer { padding: 0 24px 20px; border-top: 1px solid var(--border); font-size: 0.9rem; line-height: 1.6; color: var(--text); }
.faq-answer p { margin: 0; padding-top: 12px; }
</style>
