<script is:inline>
  // Buyback Estimator Logic
  const priceData = {
    laptop: {
      apple: { brand: 'Apple', base: 80000 },
      dell: { brand: 'Dell', base: 45000 },
      hp: { brand: 'HP', base: 42000 },
      lenovo: { brand: 'Lenovo', base: 48000 }
    },
    phone: {
      apple: { brand: 'Apple', base: 65000 },
      samsung: { brand: 'Samsung', base: 55000 }
    }
  };

  const ageFactors = { '1': 0.7, '3': 0.4, '5': 0.15 };

  function updateEstimator() {
    const type = document.querySelector('.est-type-btn.active').dataset.type;
    const brand = document.getElementById('est-brand').value;
    const age = document.getElementById('est-age').value;
    
    // Simple calc hack for demo/landing page
    let base = 30000;
    if (priceData[type] && priceData[type][brand]) base = priceData[type][brand].base;
    
    let factor = ageFactors[age] || 0.5;
    let price = Math.round(base * factor);
    let topPrice = Math.round(price * 1.15);
    
    document.querySelector('.est-price').textContent = `₹${price.toLocaleString()} – ₹${topPrice.toLocaleString()}`;
    document.querySelector('.est-desc').textContent = `${brand.toUpperCase()} ${type} · ${age}yr · Good Condition`;
  }

  document.querySelectorAll('.est-type-btn').forEach(btn => {
    btn.onclick = () => {
      document.querySelectorAll('.est-type-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      updateEstimator();
    };
  });

  document.getElementById('est-brand').onchange = updateEstimator;
  document.getElementById('est-age').onchange = updateEstimator;
  
  updateEstimator();
</script>
