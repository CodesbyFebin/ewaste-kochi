---
// src/pages/index.astro — 12,000+ SEO Authority Hub & Landing Page
// Blending legacy authority system with the new high-converting conversion UI
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Chatbot from '../components/Chatbot.astro';
import { contact } from '../data/contact.js';
import { services } from '../data/services.js';
import { locations } from '../data/locations.js';

const pageTitle = "Kochi'sMost Trusted E-Waste Recycling & Data Destruction | EWaste Kochi";
const pageDesc = "NIST 800-88 certified data destruction. Hard drive shredding. Laptop & phone buyback. KSPCB-authorized recycler serving Infopark, Smart City & all Kerala. DPDP Act 2023 compliant.";

const organizationSchema = {
  '@type': 'LocalBusiness',
  name: 'EWaste Kochi',
  description: 'Certified E-Waste Recycling & ITAD Services in Kerala',
  areaServed: 'Kerala',
  knowsAbout: ['Electronics Recycling', 'IT Asset Disposition', 'Data Destruction', 'DPDP Act Compliance']
};
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  schema={organizationSchema}
  canonical="https://ewastekochi.com/"
>

  <!-- TOP TICKER -->
  <div class="top-ticker">
    <div class="wrap">
      <div class="ticker-inner">
        <span>♻️ FREE CORPORATE PICKUP — 50+ UNITS ACROSS KOCHI</span>
        <span>🔒 NIST 800-88 CERTIFIED DATA DESTRUCTION</span>
        <span>📋 CERTIFICATE OF DESTRUCTION — EVERY DEVICE</span>
        <span>⚖️ DPDP ACT 2023 COMPLIANT ITAD</span>
        <span>🏢 SERVING INFOPARK, SMARTCITY, TECHNOPARK CLIENTS</span>
        <span class="ticker-phone">📞 24/7 CORPORATE EMERGENCY: <a href="tel:+919876543210">+91-9876-543-210</a></span>
      </div>
    </div>
  </div>

  <Navbar currentPath="/" />

  <main id="main-content">
    
    <!-- MASTER HERO -->
    <section class="hero-v3">
      <div class="wrap">
        <div class="hero-grid">
          <div class="hero-content">
            <div class="hero-eyebrow">Kerala's #1 Certified ITAD Facility</div>
            <h1 class="hero-title">
              Kochi's Most Trusted<br/>
              <span class="text-green">E-Waste Recycling</span><br/>
              & Data Destruction
            </h1>
            <p class="hero-text">
              NIST 800-88 certified data destruction. Hard drive shredding. Laptop & phone buyback. Certificate of Destruction issued for every device. DPDP Act 2023 compliant — protecting Kerala businesses from data breach liability.
            </p>
            <div class="hero-ctas">
              <a href="#quote" class="btn btn-primary btn-lg">📋 Get Free Quote</a>
              <a href={contact.whatsappMessage} target="_blank" class="btn btn-wa btn-lg">💬 WhatsApp Us</a>
              <a href="#buyback" class="btn btn-outline btn-lg">💻 Check Buyback Price</a>
            </div>
            <div class="hero-trust">
              <div class="trust-pill">✓ KSPCB Authorized</div>
              <div class="trust-pill">✓ NIST 800-88</div>
              <div class="trust-pill">✓ DoD 5220.22-M</div>
              <div class="trust-pill">✓ Free Bulk Pickup</div>
              <div class="trust-pill">✓ CoD Every Job</div>
            </div>
          </div>

          <div class="hero-visual">
            <div class="compliance-card">
              <div class="cc-header">
                <span class="cc-tag">NIST 800-88 SECURE</span>
                <span class="cc-status">● SECURE WIPE IN PROGRESS</span>
              </div>
              <div class="cc-body">
                <div class="cc-stat">
                  <div class="cc-stat-label">DDR5 32GB / 1TB HDD</div>
                  <div class="cc-stat-val">CERTIFIED WIPE</div>
                </div>
                <div class="progress-container">
                  <div class="progress-bar" style="width: 42%"></div>
                  <span class="progress-text">PASS 3/7 — 42%</span>
                </div>
                <div class="cc-footer">
                   <div class="cc-badge">NIST CERTIFIED</div>
                   <div class="cc-badge">KSPCB AUTH</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="hero-stats">
          <div class="hstat">
            <span class="hstat-num">5,200+</span>
            <span class="hstat-label">Devices Processed</span>
          </div>
          <div class="hstat">
            <span class="hstat-num">200+</span>
            <span class="hstat-label">Corporate Clients</span>
          </div>
          <div class="hstat">
            <span class="hstat-num">0</span>
            <span class="hstat-label">Data Breach Incidents</span>
          </div>
          <div class="hstat">
            <span class="hstat-num">100%</span>
            <span class="hstat-label">CoD Issuance Rate</span>
          </div>
          <div class="hstat">
            <span class="hstat-num">24/7</span>
            <span class="hstat-label">Corporate Pickup</span>
          </div>
          <div class="hstat">
            <span class="hstat-num">4.9 ★</span>
            <span class="hstat-label">Google Reviews</span>
          </div>
        </div>
      </div>
    </section>

    <!-- DPDP ACT WARNING -->
    <section class="compliance-warning">
      <div class="wrap">
        <div class="warning-box">
          <div class="warning-icon">⚖️</div>
          <div class="warning-content">
            <h3>DPDP Act 2023 — Now Enforceable in India</h3>
            <p>Under India's Digital Personal Data Protection Act 2023, businesses disposing of IT equipment containing personal data without a Certificate of Destruction face penalties up to <strong>₹250 Crore</strong>. Giving laptops to scrap dealers or using uncertified vendors makes you legally liable. EWaste Kochi provides full DPDP compliance documentation.</p>
          </div>
          <a href="/itad" class="btn btn-outline btn-sm">Learn more →</a>
        </div>
      </div>
    </section>

    <!-- SERVICES GRID -->
    <section class="section" id="services">
      <div class="wrap">
        <div class="text-center" style="margin-bottom:60px">
          <div class="sec-eyebrow">Our Services</div>
          <h2 class="sec-title">Complete ITAD & <br/><em>E-Waste Solutions</em></h2>
          <p class="sec-sub">From individual laptop buyback to enterprise-scale IT asset disposition — every service is certified, documented, and DPDP Act compliant.</p>
        </div>

        <div class="services-v3-grid">
          <div class="svc-card">
            <div class="svc-icon">🏢</div>
            <h3>Corporate ITAD</h3>
            <p>End-to-end IT Asset Disposition for Kochi businesses. Full inventory, certified data destruction, and audit-ready reporting.</p>
            <div class="svc-price">From ₹150/device</div>
            <a href="/itad" class="svc-link">Learn More →</a>
          </div>
          <div class="svc-card">
            <div class="svc-icon">💾</div>
            <h3>Certified Data Destruction</h3>
            <p>NIST 800-88 and DoD 5220.22-M certified data wiping for HDDs, SSDs, smartphones, and servers.</p>
            <div class="svc-price">From ₹200/drive</div>
            <a href="/itad#data-destruction" class="svc-link">Learn More →</a>
          </div>
          <div class="svc-card">
            <div class="svc-icon">⚙️</div>
            <h3>Hard Drive Shredding</h3>
            <p>Physical destruction of HDDs, SSDs, NVMe drives, and optical media. On-site shredding available for banks.</p>
            <div class="svc-price">From ₹350/drive</div>
            <a href="/itad#shredding" class="svc-link">Learn More →</a>
          </div>
          <div class="svc-card">
            <div class="svc-icon">💻</div>
            <h3>Laptop Buyback</h3>
            <p>Best prices for old laptops in Kochi. MacBooks up to ₹85,000. 15–20% above Cashify for business models.</p>
            <div class="svc-price">Up to ₹85,000</div>
            <a href="/pickup" class="svc-link">Get Estimate →</a>
          </div>
          <div class="svc-card">
            <div class="svc-icon">📱</div>
            <h3>Phone Buyback</h3>
            <p>Certified forensic wipe before any resale. Best prices for iPhones and Samsung devices in Kerala.</p>
            <div class="svc-price">Up to ₹75,000</div>
            <a href="/pickup" class="svc-link">Get Estimate →</a>
          </div>
          <div class="svc-card">
            <div class="svc-icon">🏗️</div>
            <h3>Office Clearance</h3>
            <p>Complete office IT clearance for relocation or downsizing. Logistics, asset valuation, and recycling managed.</p>
            <div class="svc-price">Custom Pricing</div>
            <a href="/contact" class="svc-link">Get Quote →</a>
          </div>
        </div>

        <div class="text-center" style="margin-top:40px">
          <a href="/services" class="btn btn-outline">View All Services →</a>
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="section-alt">
      <div class="wrap">
        <div class="text-center" style="margin-bottom:60px">
          <div class="sec-eyebrow">Simple Process</div>
          <h2 class="sec-title">How It <em>Works</em></h2>
        </div>
        <div class="process-steps">
          <div class="step-item">
            <div class="step-num">01</div>
            <h4>Request a Quote</h4>
            <p>Call, WhatsApp, or fill out our form. Get a response within 2 hours.</p>
          </div>
          <div class="step-item">
            <div class="step-num">02</div>
            <h4>Free Pickup</h4>
            <p>We collect from your location across Kochi. Chain-of-custody starts here.</p>
          </div>
          <div class="step-item">
            <div class="step-num">03</div>
            <h4>Certified Wipe</h4>
            <p>NIST 800-88 certified overwrite. Every device tracked by serial number.</p>
          </div>
          <div class="step-item">
            <div class="step-num">04</div>
            <h4>CoD Issued</h4>
            <p>Certificate of Destruction issued per device within 24 hours.</p>
          </div>
          <div class="step-item">
            <div class="step-num">05</div>
            <h4>Payment</h4>
            <p>Same-day payment for buyback devices via UPI or bank transfer.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- BUYBACK ESTIMATOR -->
    <section class="section" id="buyback">
      <div class="wrap">
        <div class="estimator-layout">
          <div class="estimator-info">
             <div class="sec-eyebrow">Instant Price Check</div>
             <h2 class="sec-title">Buyback Price <em>Estimator</em></h2>
             <p class="sec-sub">We consistently beat Cashify by 15–20% on business-grade laptops and high-end smartphones.</p>
             <div class="comparison-tiny">
                <div class="comp-row"><span>Cashify estimate</span> <del>₹36,000</del></div>
                <div class="comp-row"><span>EWaste Kochi</span> <strong class="text-green">₹44,500+</strong></div>
             </div>
          </div>
          <div class="estimator-card">
             <div class="est-form">
                <div class="est-row">
                   <button class="est-type-btn active" data-type="laptop">💻 Laptop</button>
                   <button class="est-type-btn" data-type="phone">📱 Phone</button>
                </div>
                <div class="fgroup">
                   <label>Brand</label>
                   <select id="est-brand">
                      <option value="apple">Apple (Mac/iPhone)</option>
                      <option value="dell">Dell / Latitude</option>
                      <option value="hp">HP / EliteBook</option>
                      <option value="lenovo">Lenovo / ThinkPad</option>
                   </select>
                </div>
                <div class="fgroup">
                   <label>Age</label>
                   <select id="est-age">
                      <option value="1">1–2 years</option>
                      <option value="3">3–4 years</option>
                      <option value="5">5+ years</option>
                   </select>
                </div>
                <div id="est-result" class="est-result">
                   <div class="est-price">₹44,500 – ₹50,000</div>
                   <div class="est-desc">Apple laptop · 1-2yr · Good Condition</div>
                </div>
                <a id="est-wa-link" href={contact.whatsappMessage} target="_blank" class="btn btn-wa btn-full">💬 Confirm on WhatsApp</a>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- AUTHORITY GATEWAYS (Old Style Blending) -->
    <section class="section-alt">
      <div class="wrap">
        <div class="text-center" style="margin-bottom:60px">
          <h2 class="sec-title">The Three <em>Authority</em> Pillars</h2>
          <p class="sec-sub">Deep-dive technical encyclopedias on hardware retirement and compliance.</p>
        </div>
        <div class="pillar-grid-v3">
          <a href="/ewaste" class="pillar-card pc-green">
            <h3>E-Waste Encyclopedia</h3>
            <p>20,000+ words on e-waste laws, material recovery, and toxic chemistry.</p>
            <span>ENTRANCE →</span>
          </a>
          <a href="/itad" class="pillar-card pc-blue">
            <h3>ITAD Authority</h3>
            <p>Certified IT asset disposition, NIST data destruction, and compliance manuals.</p>
            <span>ENTRANCE →</span>
          </a>
          <a href="/recycling" class="pillar-card pc-amber">
            <h3>Recycling Tech</h3>
            <p>Deep dive into urban mining, shredding tech, and processing mechanics.</p>
            <span>ENTRANCE →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- GEOGRAPHIC REACH -->
    <section class="section">
       <div class="wrap">
         <div class="text-center" style="margin-bottom:50px">
            <h2 class="sec-title">569 Local <em>Authority</em> Zones</h2>
            <p class="sec-sub">Free corporate collection and localized compliance across Ernakulam district.</p>
         </div>
         <div class="loc-grid-v3">
            {locations.slice(0, 16).map(loc => (
              <a href={`/locations/${loc.slug}`} class="loc-chip-v3">
                {loc.name}
              </a>
            ))}
            <a href="/locations" class="loc-chip-v3 active">VIEW ALL 569 ZONES →</a>
         </div>
       </div>
    </section>

    <!-- CONTACT / QUOTE -->
    <section class="section-alt" id="quote">
      <div class="wrap">
        <div class="quote-layout">
          <div class="quote-info">
            <h2 class="sec-title">Get Your <em>Free Quote</em></h2>
            <p>2-hour response guaranteed. No commitment required.</p>
            <div class="quote-contact">
              <div>📞 <strong>Call / WhatsApp 24/7</strong><br/>{contact.phoneDisplay}</div>
              <div>✉️ <strong>Email</strong><br/>{contact.email}</div>
              <div>📍 <strong>Visit Us</strong><br/>710A Hill Palace Rd, Thrippunithura, Kochi 682301</div>
            </div>
          </div>
          <div class="quote-form-card">
            <form id="hp-quote-form" class="hform">
              <div class="fgroup">
                <label>Full Name</label>
                <input type="text" placeholder="Rahul Sharma" required>
              </div>
              <div class="frow">
                <div class="fgroup">
                  <label>Phone</label>
                  <input type="tel" placeholder="+91..." required>
                </div>
                <div class="fgroup">
                  <label>Service</label>
                  <select>
                    <option>Corporate ITAD</option>
                    <option>Buyback Estimate</option>
                    <option>Data Destruction</option>
                  </select>
                </div>
              </div>
              <div class="fgroup">
                <label>Details</label>
                <textarea rows="3" placeholder="Volume, location, requirements..."></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-full">📤 Send Request</button>
            </form>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <Chatbot />

</BaseLayout>

<style>
  /* Ticker */
  .top-ticker { background: #000; border-bottom: 1px solid var(--border); padding: 10px 0; overflow: hidden; }
  .ticker-inner { display: flex; gap: 40px; white-space: nowrap; animation: ticker 40s linear infinite; font-size: 0.7rem; font-weight: 700; color: var(--muted); }
  @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .ticker-phone { color: var(--green); }

  /* Hero V3 */
  .hero-v3 { padding: 80px 0 60px; background: radial-gradient(circle at 70% 30%, rgba(0,232,150,0.05), transparent), #050908; }
  .hero-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; align-items: center; margin-bottom: 60px; }
  .hero-eyebrow { color: var(--green); font-weight: 800; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 20px; }
  .hero-title { font-size: clamp(3rem, 6vw, 4.2rem); line-height: 1; letter-spacing: -0.04em; margin-bottom: 25px; }
  .text-green { color: var(--green); }
  .hero-text { font-size: 1.15rem; color: var(--text); line-height: 1.6; margin-bottom: 40px; max-width: 600px; }
  .hero-ctas { display: flex; gap: 15px; flex-wrap: wrap; }
  .hero-trust { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 40px; }
  .trust-pill { font-size: 0.65rem; font-weight: 700; border: 1px solid var(--border); padding: 4px 12px; border-radius: 20px; color: var(--muted); }

  /* Compliance Card Anim */
  .compliance-card { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 30px; border-top: 3px solid var(--green); box-shadow: 0 40px 80px rgba(0,0,0,0.5); }
  .cc-header { display: flex; justify-content: space-between; margin-bottom: 30px; }
  .cc-tag { font-size: 0.65rem; font-weight: 800; color: var(--green); }
  .cc-status { font-size: 0.65rem; color: var(--muted); }
  .cc-stat-label { font-size: 0.75rem; color: var(--white); margin-bottom: 5px; }
  .cc-stat-val { font-size: 0.9rem; font-weight: 800; color: var(--green); margin-bottom: 15px; }
  .progress-container { width: 100%; height: 10px; background: var(--border); border-radius: 10px; position: relative; margin-bottom: 30px; }
  .progress-bar { height: 100%; background: var(--green); border-radius: 10px; }
  .progress-text { position: absolute; top: 18px; right: 0; font-size: 0.7rem; color: var(--muted); font-weight: 700; }
  .cc-footer { display: flex; gap: 10px; }
  .cc-badge { font-size: 0.6rem; background: var(--border); padding: 3px 8px; border-radius: 4px; color: var(--muted); font-weight: 700; }

  /* Stats */
  .hero-stats { display: flex; justify-content: space-between; gap: 20px; padding-top: 40px; border-top: 1px solid var(--border); flex-wrap: wrap; }
  .hstat { flex: 1; min-width: 140px; }
  .hstat-num { display: block; font-size: 1.8rem; font-weight: 800; color: var(--white); letter-spacing: -0.02em; }
  .hstat-label { font-size: 0.65rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; }

  /* Compliance Warning */
  .compliance-warning { padding: 40px 0; }
  .warning-box { background: rgba(0,232,150,0.03); border: 1px solid rgba(0,232,150,0.3); border-radius: 20px; padding: 30px; display: grid; grid-template-columns: 60px 1fr auto; gap: 30px; align-items: center; }
  .warning-icon { font-size: 2.5rem; }
  .warning-content h3 { font-size: 1.25rem; color: var(--white); margin-bottom: 10px; }
  .warning-content p { font-size: 0.95rem; color: var(--text); line-height: 1.6; }
  .warning-content strong { color: var(--green); }

  /* Services V3 */
  .services-v3-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
  .svc-card { background: var(--card); border: 1px solid var(--border); padding: 35px; border-radius: 20px; transition: 0.3s; }
  .svc-card:hover { border-color: var(--green); transform: translateY(-5px); }
  .svc-icon { font-size: 2.2rem; margin-bottom: 20px; }
  .svc-card h3 { font-size: 1.1rem; margin-bottom: 12px; }
  .svc-card p { font-size: 0.85rem; color: var(--muted); margin-bottom: 20px; line-height: 1.5; }
  .svc-price { font-size: 0.75rem; font-weight: 800; color: var(--green); text-transform: uppercase; margin-bottom: 15px; }
  .svc-link { font-size: 0.8rem; font-weight: 700; color: var(--white); }

  /* Process */
  .process-steps { display: grid; grid-template-columns: repeat(5, 1fr); gap: 30px; }
  .step-item { position: relative; }
  .step-num { font-size: 2.5rem; font-weight: 800; color: rgba(0,232,150,0.1); margin-bottom: 10px; }
  .step-item h4 { font-size: 1rem; margin-bottom: 10px; }
  .step-item p { font-size: 0.8rem; color: var(--muted); line-height: 1.6; }

  /* Estimator */
  .estimator-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .comparison-tiny { margin-top: 30px; display: flex; flex-direction: column; gap: 10px; }
  .comp-row { display: flex; justify-content: space-between; font-size: 0.85rem; border-bottom: 1px solid var(--border); padding-bottom: 8px; }
  .estimator-card { background: var(--card); border: 1px solid var(--border); padding: 40px; border-radius: 20px; }
  .est-row { display: flex; gap: 10px; margin-bottom: 25px; }
  .est-type-btn { flex: 1; padding: 12px; background: var(--border); border: none; border-radius: 10px; color: var(--muted); font-weight: 700; cursor: pointer; transition: 0.2s; }
  .est-type-btn.active { background: var(--green); color: #000; }
  .est-result { background: rgba(0,232,150,0.05); padding: 25px; border-radius: 15px; margin: 20px 0; border: 1px dashed var(--green); }
  .est-price { font-size: 1.8rem; font-weight: 800; color: var(--white); }
  .est-desc { font-size: 0.8rem; color: var(--muted); margin-top: 5px; }
  .btn-full { width: 100%; justify-content: center; }

  /* Pillars V3 */
  .pillar-grid-v3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
  .pillar-card { background: var(--card); border: 1px solid var(--border); padding: 40px; border-radius: 30px; transition: 0.3s; text-decoration: none; }
  .pillar-card:hover { transform: translateY(-10px); }
  .pillar-card h3 { font-size: 1.25rem; margin-bottom: 15px; }
  .pillar-card p { font-size: 0.9rem; color: var(--muted); margin-bottom: 25px; }
  .pillar-card span { font-size: 0.75rem; font-weight: 800; }
  .pc-green { border-top: 4px solid var(--green); }
  .pc-green span { color: var(--green); }
  .pc-blue { border-top: 4px solid #00B4FF; }
  .pc-blue span { color: #00B4FF; }
  .pc-amber { border-top: 4px solid #F5A623; }
  .pc-amber span { color: #F5A623; }

  /* Geo V3 */
  .loc-grid-v3 { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
  .loc-chip-v3 { padding: 10px 20px; border: 1px solid var(--border); border-radius: 40px; font-size: 0.75rem; font-weight: 700; color: var(--muted); }
  .loc-chip-v3.active { background: var(--green); color: #000; border-color: var(--green); }

  /* Quote V3 */
  .quote-layout { display: grid; grid-template-columns: 1fr 1.2fr; gap: 80px; align-items: center; }
  .quote-contact { margin-top: 40px; display: flex; flex-direction: column; gap: 25px; }
  .quote-contact strong { color: var(--white); display: block; font-size: 0.9rem; margin-bottom: 4px; }
  .quote-contact div { color: var(--muted); font-size: 0.85rem; }
  .quote-form-card { background: var(--card); border: 1px solid var(--border); padding: 40px; border-radius: 30px; }
