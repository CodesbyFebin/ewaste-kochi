---
// src/pages/[pillar].astro — Pillar landing pages (10 total)
import BaseLayout from '../layouts/BaseLayout.astro';
import pillarsData from '../data/pillars.json';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FaqSection from '../components/FaqSection.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

export function getStaticPaths() {
  return pillarsData.map((pillar) => ({
    params: { pillar: pillar.slug },
    props: { pillar },
  }));
}

const { pillar } = Astro.props;
const BASE = 'https://ewastekochi.com';
const canonical = `${BASE}/${pillar.slug}/`;

const breadcrumbs = [
  { name: 'Home', url: `${BASE}/` },
  { name: pillar.name, url: canonical },
];

// ItemList schema for the 10 clusters
const itemListSchema = {
  '@type': 'ItemList',
  name: `${pillar.name} — Topic Clusters`,
  numberOfItems: pillar.clusters.length,
  itemListElement: pillar.clusters.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    url: `${BASE}/${pillar.slug}/${c.id}/`,
  })),
};

// Sample FAQs for this pillar (first 6)
const pillarFaqs = [
  { q: `What is ${pillar.name}?`, a: pillar.description },
  { q: `Why is ${pillar.name} important for Kerala businesses?`, a: pillar.intro },
];
---

<BaseLayout
  title={pillar.metaTitle}
  description={pillar.metaDesc}
  canonical={canonical}
  schema={itemListSchema}
  faqs={pillarFaqs}
  breadcrumbs={breadcrumbs}
>
  <Breadcrumbs items={breadcrumbs} />

  <!-- Hero -->
  <section class="pillar-hero section">
    <div class="wrap">
      <span class="sec-eyebrow">{pillar.icon} {pillar.name}</span>
      <h1 class="sec-title">{pillar.h1}</h1>
      <p class="sec-sub">{pillar.metaDesc}</p>
      <div class="pillar-ctas">
        <a href="https://wa.me/919876543210" class="btn btn-wa btn-lg" data-track="pillar-wa">
          <span>💬</span> Get Free Quote
        </a>
        <a href="/contact/" class="btn btn-outline btn-lg">Schedule Pickup</a>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="section-alt">
    <div class="wrap">
      <div class="pillar-intro-grid">
        <div class="pillar-intro-content">
          <span class="sec-eyebrow">Overview</span>
          <h2 class="sec-title">Why <em>{pillar.name}</em> Matters in Kerala</h2>
          <p style="color:var(--text); line-height:1.85; font-size:.97rem;">{pillar.intro}</p>
        </div>
        <div class="pillar-intro-badges">
          <div class="trust-card">
            <div class="trust-icon">✅</div>
            <div>
              <strong>KSPCB Authorised</strong>
              <p>Kerala's only certified recycler</p>
            </div>
          </div>
          <div class="trust-card">
            <div class="trust-icon">🔐</div>
            <div>
              <strong>NIST 800-88</strong>
              <p>Certified data destruction</p>
            </div>
          </div>
          <div class="trust-card">
            <div class="trust-icon">📜</div>
            <div>
              <strong>Certificate Issued</strong>
              <p>Every device, every time</p>
            </div>
          </div>
          <div class="trust-card">
            <div class="trust-icon">🌱</div>
            <div>
              <strong>Zero Landfill</strong>
              <p>100% material recovery</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cluster Grid -->
  <section class="section">
    <div class="wrap">
      <div class="text-center">
        <span class="sec-eyebrow">Topic Clusters</span>
        <h2 class="sec-title">10 Deep-Dive <em>Topic Areas</em></h2>
        <p class="sec-sub">Each cluster contains 100+ in-depth articles on specific {pillar.name.toLowerCase()} questions.</p>
      </div>
      <div class="cluster-grid">
        {pillar.clusters.map((cluster, idx) => (
          <a href={`/${pillar.slug}/${cluster.id}/`} class="cluster-card">
            <span class="cluster-num">0{idx + 1}</span>
            <h3 class="cluster-name">{cluster.name}</h3>
            <p class="cluster-kw">{cluster.keyword}</p>
            <span class="cluster-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Pillar FAQs -->
  <FaqSection faqs={pillarFaqs} heading={`${pillar.name} — Frequently Asked Questions`} />

  <!-- CTA -->
  <section class="section-alt">
    <div class="wrap text-center">
      <span class="sec-eyebrow">Get Started</span>
      <h2 class="sec-title">Ready to Handle Your <em>{pillar.name}</em>?</h2>
      <p class="sec-sub">Same-day response for corporate clients. Free bulk pickup across Ernakulam.</p>
      <div class="pillar-ctas">
        <a href="https://wa.me/919876543210" class="btn btn-wa btn-lg">💬 WhatsApp Us</a>
        <a href="tel:+919876543210" class="btn btn-outline btn-lg">📞 Call Now</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.pillar-hero { background: radial-gradient(ellipse at 60% 40%, rgba(0,232,150,.08) 0%, transparent 60%), var(--bg); }
.pillar-ctas { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 2rem; }
.pillar-intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.pillar-intro-badges { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.trust-card { display: flex; gap: 14px; align-items: flex-start; background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 18px; }
.trust-icon { font-size: 1.6rem; flex-shrink: 0; }
.trust-card strong { display: block; color: var(--white); font-size: .88rem; margin-bottom: 4px; }
.trust-card p { font-size: .78rem; color: var(--muted); margin: 0; }
.cluster-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 3rem; }
.cluster-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 28px; display: flex; flex-direction: column; gap: 10px; transition: all .22s; text-decoration: none; }
.cluster-card:hover { border-color: rgba(0,232,150,.35); background: var(--card2); transform: translateY(-3px); }
.cluster-num { font-size: .65rem; font-weight: 700; color: var(--green); letter-spacing: .15em; font-family: var(--mono); }
.cluster-name { font-size: 1.05rem; font-weight: 700; color: var(--white); margin: 0; }
.cluster-kw { font-size: .78rem; color: var(--muted); margin: 0; }
.cluster-arrow { color: var(--green); font-size: 1.1rem; margin-top: auto; }
@media (max-width: 900px) {
  .pillar-intro-grid { grid-template-columns: 1fr; gap: 36px; }
  .pillar-intro-badges { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .pillar-intro-badges { grid-template-columns: 1fr; }
  .cluster-grid { grid-template-columns: 1fr; }
}
</style>
