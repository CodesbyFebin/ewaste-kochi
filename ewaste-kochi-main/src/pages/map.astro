---
// src/pages/map.astro — Drop-off Centers Map (Add-on Module)
// Uses Leaflet.js for interactive map — no API key needed
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { dropoffLocations, locationTypes } from '../data/dropoffLocations.js';
import { contact } from '../data/contact.js';

const pageTitle = 'E-Waste Drop-off Centers Kochi | Map | EWaste Kochi';
const pageDesc = 'Find the nearest e-waste drop-off center or collection hub in Kochi. 8 certified locations across Ernakulam — Infopark, Smart City, MG Road, Lulu Mall, Fort Kochi and more.';

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'Drop-off Map', url: 'https://ewastekochi.com/map' },
];

const locSchema = {
  '@type': 'ItemList',
  name: 'EWaste Kochi Drop-off Locations',
  numberOfItems: dropoffLocations.length,
  itemListElement: dropoffLocations.map((loc, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'LocalBusiness',
      name: loc.name,
      address: loc.address,
      telephone: loc.phone,
      openingHours: loc.hours,
    },
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  schema={locSchema}
  breadcrumbs={breadcrumbs}
  canonical="https://ewastekochi.com/map"
>
  <Navbar currentPath="/map" />

  <main id="main-content">

    <!-- HERO -->
    <section class="map-hero">
      <div class="wrap">
        <div class="map-hero-inner">
          <div>
            <div class="sec-eyebrow">8 Certified Locations · Kochi</div>
            <h1 class="sec-title">Find a <em>Drop-off Center</em></h1>
            <p class="sec-sub" style="margin-top:16px">
              Can't wait for pickup? Drop your e-waste at any of our certified centers across Kochi — no appointment needed for most items.
            </p>
            <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:20px">
              {Object.entries(locationTypes).map(([key, t]) => (
                <button class="type-filter btn btn-sm btn-outline active" data-type={key} id={`filter-${key}`}>
                  {t.icon} {t.label}
                </button>
              ))}
              <button class="type-filter btn btn-sm btn-primary active" data-type="all" id="filter-all">
                🗺️ Show All
              </button>
            </div>
          </div>
          <div class="map-hero-cta">
            <a href="/pickup" class="btn btn-primary btn-lg">🚀 Schedule Free Pickup Instead →</a>
            <a href={contact.phoneLink} class="btn btn-outline btn-lg">📞 Call for Directions</a>
          </div>
        </div>
      </div>
    </section>

    <!-- MAP + LIST LAYOUT -->
    <section class="section">
      <div class="wrap">
        <div class="map-layout">

          <!-- LOCATION LIST  -->
          <div class="loc-list-wrap">
            <div class="loc-search-bar">
              <input
                id="loc-search"
                type="search"
                placeholder="Search by name or area…"
                aria-label="Search locations"
              >
            </div>

            <div class="loc-list" id="loc-list" role="list">
              {dropoffLocations.map(loc => {
                const t = locationTypes[loc.type];
                return (
                  <div
                    class="loc-card"
                    data-id={loc.id}
                    data-type={loc.type}
                    data-lat={loc.lat}
                    data-lng={loc.lng}
                    role="listitem"
                    tabindex="0"
                    aria-label={`${loc.name} — ${loc.address}`}
                  >
                    <div class="lc-header">
                      <span class="lc-type-dot" style={`background:${t.color}`}></span>
                      <div>
                        <strong class="lc-name">{loc.name}</strong>
                        <span class="lc-badge" style={`color:${t.color};border-color:${t.color}30`}>{t.icon} {loc.badge}</span>
                      </div>
                    </div>
                    <p class="lc-addr">📍 {loc.address}</p>
                    <p class="lc-hours">🕐 {loc.hours}</p>
                    <div class="lc-accepts">
                      {loc.accepts.slice(0, 4).map(item => (
                        <span class="lc-chip">{item}</span>
                      ))}
                      {loc.accepts.length > 4 && <span class="lc-chip lc-more">+{loc.accepts.length - 4} more</span>}
                    </div>
                    <div class="lc-actions">
                      {loc.freePickup && <span class="badge badge-g">✓ Free Pickup</span>}
                      {loc.certified && <span class="badge badge-b">✓ KSPCB Certified</span>}
                      <a
                        href={`https://www.google.com/maps/search/?api=1&query=${loc.lat},${loc.lng}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-outline btn-sm"
                        aria-label={`Get directions to ${loc.name}`}
                      >
                        Get Directions →
                      </a>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- MAP PANEL -->
          <div class="map-panel">
            <div id="map-container" role="application" aria-label="Interactive map of drop-off locations">
              <div id="drop-map"></div>
            </div>
            <div class="map-legend" role="complementary" aria-label="Map legend">
              {Object.entries(locationTypes).map(([key, t]) => (
                <div class="legend-item">
                  <span class="legend-dot" style={`background:${t.color}`}></span>
                  <span>{t.icon} {t.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA STRIP -->
    <section class="section-alt">
      <div class="wrap text-center">
        <h2 class="sec-title">Not Near a Center? <em>We Come to You.</em></h2>
        <p class="sec-sub" style="margin:16px auto 32px">Free pickup for 10+ items across all 569 zones in Ernakulam. Same‑day available for corporate collections.</p>
        <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
          <a href="/pickup" class="btn btn-primary btn-lg">🚀 Book Free Pickup →</a>
          <a href={contact.whatsappMessage} target="_blank" rel="noopener noreferrer" class="btn btn-wa btn-lg">💬 WhatsApp Us</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<!-- Leaflet CSS + JS (open source, no API key) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WLcE=" crossorigin=""></script>

<script define:vars={{ dropoffLocations, locationTypes }}>
  // Initialize Leaflet map when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    const map = L.map('drop-map', {
      center: [9.9817, 76.2981],
      zoom: 11,
      zoomControl: true,
    });

    // Dark tile layer (Carto Dark Matter — free)
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 20,
    }).addTo(map);

    const markerColors = { main: '#00E896', hub: '#00B4FF', kiosk: '#F5A623' };
    const markers = {};

    dropoffLocations.forEach(loc => {
      const color = markerColors[loc.type] || '#00E896';
      const icon = L.divIcon({
        className: '',
        html: `<div style="width:16px;height:16px;background:${color};border:2.5px solid rgba(0,0,0,0.6);border-radius:50%;box-shadow:0 0 0 4px ${color}33"></div>`,
        iconSize: [16, 16],
        iconAnchor: [8, 8],
      });

      const marker = L.marker([loc.lat, loc.lng], { icon })
        .addTo(map)
        .bindPopup(`
          <div style="font-family:sans-serif;min-width:220px">
            <strong style="color:${color};font-size:.9rem">${locationTypes[loc.type].icon} ${loc.name}</strong><br>
            <span style="font-size:.78rem;color:#aaa">${loc.badge}</span>
            <hr style="border-color:#333;margin:8px 0">
            <span style="font-size:.78rem">📍 ${loc.address}</span><br>
            <span style="font-size:.78rem">🕐 ${loc.hours}</span><br>
            <span style="font-size:.78rem">📞 <a href="tel:${loc.phone}" style="color:${color}">${loc.phone}</a></span>
            <hr style="border-color:#333;margin:8px 0">
            <a href="https://www.google.com/maps/search/?api=1&query=${loc.lat},${loc.lng}" target="_blank"
               style="font-size:.78rem;color:${color};text-decoration:underline">Get Directions →</a>
          </div>
        `, { className: 'dark-popup' });

      markers[loc.id] = marker;
    });

    // Click location card => fly to marker
    document.querySelectorAll('.loc-card').forEach(card => {
      card.addEventListener('click', () => {
        const id = parseInt(card.dataset.id);
        const lat = parseFloat(card.dataset.lat);
        const lng = parseFloat(card.dataset.lng);
        map.flyTo([lat, lng], 14, { duration: 0.8 });
        if (markers[id]) markers[id].openPopup();
        document.querySelectorAll('.loc-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
      });
      card.addEventListener('keydown', (e) => { if (e.key === 'Enter') card.click(); });
    });

    // Search filter
    const searchInput = document.getElementById('loc-search');
    searchInput?.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase();
      document.querySelectorAll('.loc-card').forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(q) ? '' : 'none';
      });
    });

    // Type filter buttons
    document.querySelectorAll('.type-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        const type = btn.dataset.type;
        document.querySelectorAll('.type-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.loc-card').forEach(card => {
          card.style.display = (type === 'all' || card.dataset.type === type) ? '' : 'none';
        });
      });
    });
  });
</script>

<style>
  .map-hero { padding: 80px 0 60px; border-bottom: 1px solid var(--border); background: radial-gradient(circle at 30% 60%, rgba(0,180,255,.06), transparent); }
  .map-hero-inner { display: flex; justify-content: space-between; align-items: flex-end; gap: 40px; flex-wrap: wrap; }
  .map-hero-cta { display: flex; flex-direction: column; gap: 12px; flex-shrink: 0; }
  .type-filter.active { background: rgba(0,232,150,.1) !important; border-color: var(--green) !important; color: var(--green) !important; }

  .map-layout { display: grid; grid-template-columns: 360px 1fr; gap: 32px; align-items: flex-start; }
  .loc-list-wrap { display: flex; flex-direction: column; gap: 0; height: 680px; border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; background: var(--card); }
  .loc-search-bar { padding: 16px; border-bottom: 1px solid var(--border); }
  .loc-search-bar input { width: 100%; background: var(--card2); border: 1.5px solid var(--border2); border-radius: var(--radius); color: var(--white); font-family: var(--font); font-size: .85rem; padding: 10px 14px; outline: none; }
  .loc-search-bar input:focus { border-color: rgba(0,232,150,.4); }
  .loc-list { overflow-y: auto; flex: 1; padding: 8px; display: flex; flex-direction: column; gap: 6px; }
  .loc-card { background: var(--card2); border: 1.5px solid var(--border2); border-radius: var(--radius); padding: 16px; cursor: pointer; transition: all .2s; }
  .loc-card:hover, .loc-card.active { border-color: rgba(0,232,150,.4); background: rgba(0,232,150,.04); }
  .lc-header { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
  .lc-type-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
  .lc-name { display: block; font-size: .88rem; font-weight: 700; color: var(--white); margin-bottom: 3px; }
  .lc-badge { display: inline-block; font-size: .62rem; font-weight: 700; padding: 2px 8px; border-radius: 12px; border: 1px solid; }
  .lc-addr, .lc-hours { font-size: .75rem; color: var(--muted); margin-bottom: 5px; }
  .lc-accepts { display: flex; flex-wrap: wrap; gap: 4px; margin: 8px 0; }
  .lc-chip { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; font-size: .62rem; font-weight: 600; color: var(--muted); padding: 2px 8px; }
  .lc-more { color: var(--green); border-color: rgba(0,232,150,.2); }
  .lc-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 10px; }

  .map-panel { position: sticky; top: 88px; }
  #map-container { border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border); }
  #drop-map { height: 600px; width: 100%; }
  .map-legend { display: flex; gap: 20px; flex-wrap: wrap; margin-top: 14px; padding: 14px 18px; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); }
  .legend-item { display: flex; align-items: center; gap: 8px; font-size: .75rem; color: var(--muted); }
  .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  /* Dark popup override */
  :global(.dark-popup .leaflet-popup-content-wrapper) { background: #0F1A14; border: 1px solid #162018; color: #8AB4A0; border-radius: 12px; }
  :global(.dark-popup .leaflet-popup-tip) { background: #0F1A14; }
  :global(.leaflet-popup-close-button) { color: #8AB4A0 !important; }

  @media (max-width: 1024px) {
    .map-layout { grid-template-columns: 1fr; }
    .loc-list-wrap { height: 400px; }
    .map-panel { position: static; }
    #drop-map { height: 400px; }
  }
  @media (max-width: 640px) {
    .map-hero-inner { flex-direction: column; }
  }
</style>
