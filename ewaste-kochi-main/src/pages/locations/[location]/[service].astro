---
// src/pages/locations/[location]/[service].astro — Programmatic SEO Gold
// Generates 450+ pages: /locations/kakkanad/itad-kochi, /locations/edappally/laptop-recycling, etc.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { locations } from '../../../data/locations.js';
import { services } from '../../../data/services.js';
import { contact } from '../../../data/contact.js';
import { testimonials } from '../../../data/testimonials.js';
import RelatedQuestions from '../../../components/RelatedQuestions.astro';

import mega1 from '../../../data/megaContent_part1.json';
import mega2 from '../../../data/megaContent_part2.json';
import mega3 from '../../../data/megaContent_part3.json';
import mega4 from '../../../data/megaContent_part4.json';
import mega5 from '../../../data/megaContent_part5.json';
import mega6 from '../../../data/megaContent_part6.json';
import mega7 from '../../../data/megaContent_part7.json';
import mega8 from '../../../data/megaContent_part8.json';
import mega9 from '../../../data/megaContent_part9.json';
import mega10 from '../../../data/megaContent_part10.json';
import mega11 from '../../../data/megaContent_part11.json';
import mega12 from '../../../data/megaContent_part12.json';

const megaData = { ...mega1, ...mega2, ...mega3, ...mega4, ...mega5, ...mega6, ...mega7, ...mega8, ...mega9, ...mega10, ...mega11, ...mega12 };

const getLocationBySlug = (slug) => locations.find(l => l.slug === slug);
const getServiceBySlug = (slug) => services.find(s => s.slug === slug);
const getNearbyLocations = (slug, limit) => {
  const currentIndex = locations.findIndex(l => l.slug === slug);
  return [...locations.slice(currentIndex + 1), ...locations.slice(0, currentIndex)].slice(0, limit);
};


export async function getStaticPaths() {
  return locations.flatMap(location => 
    services.map(service => ({
      params: { 
        location: location.slug,
        service: service.slug 
      },
      props: { location, service },
    }))
  );
}

const { location, service } = Astro.props as any;

// Contextual nearby locations and related services
const nearbyLocations = getNearbyLocations(location.slug, 5);
const relatedServices = service.relatedServices 
  ? service.relatedServices.map(slug => getServiceBySlug(slug)).filter(Boolean)
  : services.filter(s => s.slug !== service.slug).slice(0, 3);

const breadcrumbs = [
  { name: 'Home', url: 'https://ewastekochi.com/' },
  { name: 'Locations', url: 'https://ewastekochi.com/locations' },
  { name: location.name, url: `https://ewastekochi.com/locations/${location.slug}` },
  { name: service.shortName, url: `https://ewastekochi.com/locations/${location.slug}/${service.slug}` },
];

const pageTitle = `${service.shortName} in ${location.name} | Certified & Free Pickup | EWaste Kochi`;
const pageDesc = `Certified ${service.name.toLowerCase()} services in ${location.name}, ${location.district}. ${location.isITHub ? 'Serving IT companies with' : 'Providing'} NIST/DoD data destruction & free bulk pickup. CoD in 24h.`;

const combinedSchema = {
  "@type": "Service",
  "name": `${service.name} in ${location.name}`,
  "serviceType": service.name,
  "provider": { "@id": "https://ewastekochi.com/#organization" },
  "areaServed": {
    "@type": "City",
    "name": location.name,
    "addressRegion": "Kerala"
  },
  "description": pageDesc
};

const pageKey = `${location.slug}-${service.slug}`;
const mega = megaData[pageKey] || { content: '', faqs: [] };
const displayFaqs = mega.faqs && mega.faqs.length > 0 ? mega.faqs : (service.faqs || []);
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  schema={combinedSchema}
  breadcrumbs={breadcrumbs}
>
  <Navbar currentPath={`/locations/${location.slug}/${service.slug}`} />

  <!-- Contextual Breadcrumb -->
  <nav class="breadcrumb-nav">
    <div class="wrap">
      <ol class="breadcrumb">
        {breadcrumbs.map((crumb, i) => (
          <li>
            <a href={crumb.url}>{crumb.name}</a>
            {i < breadcrumbs.length - 1 && <span class="bc-sep">›</span>}
          </li>
        ))}
      </ol>
    </div>
  </nav>

  <!-- Localized Service Hero -->
  <section class="prog-hero">
    <div class="prog-hero-bg"></div>
    <div class="wrap">
      <div class="prog-grid">
        <div class="prog-left">
          <div class="loc-badge">{location.name} · Certified {service.category}</div>
          <h1 class="prog-h1">
            {service.shortName}<br/>
            in <span class="text-green">{location.name}</span>
          </h1>
          <p class="prog-lead">
            Need {service.shortName.toLowerCase()} in {location.name}? EWaste Kochi provides KSPCB-authorized 
            recycling and ITAD services with free bulk pickup across the {location.name} area and {location.district}.
          </p>
          
          <div class="prog-features">
            <div class="p-feat"><span>✓</span> Free Bulk Pickup in {location.name}</div>
            <div class="p-feat"><span>✓</span> NIST/DoD Data Destruction</div>
            <div class="p-feat"><span>✓</span> Certificate of Destruction</div>
            <div class="p-feat"><span>✓</span> Same-Day Quote</div>
          </div>

          <div class="prog-ctas">
            <a href="/contact" class="btn btn-primary btn-lg">Request Pickup in {location.name} →</a>
            <a href={contact.whatsappMessage} class="btn btn-wa btn-lg">💬 WhatsApp</a>
          </div>
        </div>

        <div class="prog-right">
          <div class="local-card">
            <h3>Service Status: <span class="status-live">LIVE IN {location.name.toUpperCase()}</span></h3>
            <div class="local-details">
              <div class="ld-item">
                <strong>📍 Coverage:</strong>
                <span>All areas in {location.name}, {location.district}</span>
              </div>
              <div class="ld-item">
                <strong>⏱️ Pickup:</strong>
                <span>{location.isITHub ? '2-4 Hours (Infopark Priority)' : 'Same/Next Day'}</span>
              </div>
              <div class="ld-item">
                <strong>📜 Documents:</strong>
                <span>CoD + Environmental Report Provided</span>
              </div>
            </div>
            <a href={contact.phoneLink} class="call-banner">
              📞 Call {contact.phoneDisplay}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contextual Content Section -->
  <section class="section">
    <div class="wrap">
      <div class="content-split">
        <div class="content-text">
          <h2>Professional {service.name} for {location.name} Businesses</h2>
          <div class="mega-body" set:html={mega.content}></div>
          
          <div class="standard-content">
            <p>
              Operating in {location.name}, {location.district}, {service.name} is a critical requirement for 
              maintaining environmental compliance and data security. {location.description}
            </p>
            <p>
              Our specialized {service.shortName.toLowerCase()} workflow in {location.name} ensures that your 
              old electronics are handled according to the E-Waste Management Rules 2022. For our clients in 
              {location.isITHub ? 'the IT hubs of ' : ''}{location.name}, we provide deep-level ITAD services including 
              asset tagging and secure chain-of-custody documentation.
            </p>

            <h3>Why Choose us in {location.name}?</h3>
            <ul>
              <li><strong>Local Expertise:</strong> We know {location.name} inside out, ensuring faster pickups and logistics.</li>
              <li><strong>Compliance:</strong> Fully compliant with DPDP Act 2023 for data destruction in {location.district}.</li>
              <li><strong>Transparency:</strong> Witnessed on-site destruction available for companies in {location.name}.</li>
            </ul>
          </div>
        </div>

        <aside class="content-sidebar">
          <div class="sidebar-box">
            <h4>Related in {location.name}</h4>
            <ul class="s-links">
              {relatedServices.map(s => (
                <li><a href={`/locations/${location.slug}/${s.slug}`}>{s.shortName} →</a></li>
              ))}
            </ul>
          </div>

          <div class="sidebar-box">
            <h4>Near {location.name}</h4>
            <ul class="s-links">
              {nearbyLocations.map(l => (
                <li><a href={`/locations/${l.slug}/${service.slug}`}>{service.shortName} in {l.name} →</a></li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- FAQ Section (Generated 50+ FAQs) -->
  <section class="section section-alt">
    <div class="wrap">
      <div class="text-center mb-12">
        <span class="sec-eyebrow">💡 Frequent Questions</span>
        <h2 class="sec-title">Deep Insights into {service.shortName} in {location.name}</h2>
      </div>
      
      <div class="faq-accordion-mega">
        {displayFaqs.map((faq, index) => (
          <details class="faq-details-mega">
            <summary class="faq-summary-mega">
              <span class="faq-q-text">{index + 1}. {faq.question}</span>
              <span class="faq-icon">+</span>
            </summary>
            <div class="faq-answer-mega">
              <div set:html={faq.answer}></div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .breadcrumb-nav { background: var(--surface); padding: 12px 0; border-bottom: 1px solid var(--border); }
  .breadcrumb { display: flex; gap: 8px; list-style: none; font-size: 0.8rem; color: var(--muted); }
  .bc-sep { margin-left: 8px; opacity: 0.3; }
  
  .prog-hero { padding: 80px 0; background: radial-gradient(circle at 10% 20%, rgba(0,232,150,0.05) 0%, transparent 50%); }
  .prog-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; align-items: center; }
  .loc-badge { display: inline-block; padding: 6px 14px; background: rgba(0,232,150,0.1); color: var(--green); border-radius: 20px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; margin-bottom: 20px; }
  .prog-h1 { font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.1; margin-bottom: 20px; color: var(--white); }
  .prog-lead { font-size: 1.1rem; color: var(--text); margin-bottom: 30px; font-family: var(--serif); max-width: 600px; }
  
  .prog-features { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 40px; }
  .p-feat { display: flex; align-items: center; gap: 10px; font-size: 0.85rem; color: var(--white); font-weight: 600; }
  .p-feat span { color: var(--green); }
  
  .prog-ctas { display: flex; gap: 15px; flex-wrap: wrap; }
  
  .local-card { background: var(--card); border: 1px solid var(--border2); border-radius: 20px; padding: 30px; }
  .local-card h3 { font-size: 0.8rem; color: var(--muted); margin-bottom: 20px; letter-spacing: 0.1em; }
  .status-live { color: var(--green); font-weight: 800; }
  .local-details { display: flex; flex-direction: column; gap: 15px; margin-bottom: 25px; }
  .ld-item { font-size: 0.9rem; color: var(--text); }
  .ld-item strong { display: block; color: var(--white); font-size: 0.75rem; text-transform: uppercase; margin-bottom: 4px; }
  
  .call-banner { display: block; width: 100%; text-align: center; background: var(--border2); color: var(--green); padding: 15px; border-radius: 12px; font-weight: 700; transition: background 0.3s; }
  .call-banner:hover { background: var(--border); }
  
  .content-split { display: grid; grid-template-columns: 1fr 300px; gap: 60px; }
  .content-text h2 { margin-bottom: 20px; }
  .content-text h3 { margin: 30px 0 15px; }
  .content-text ul { padding-left: 20px; margin-bottom: 20px; }
  .content-text li { margin-bottom: 10px; }
  
  .sidebar-box { background: var(--card); border: 1px solid var(--border); padding: 25px; border-radius: 15px; margin-bottom: 20px; }
  .sidebar-box h4 { font-size: 0.8rem; text-transform: uppercase; margin-bottom: 15px; color: var(--white); }
  .s-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .s-links a { font-size: 0.85rem; color: var(--muted); transition: color 0.2s; }
  .s-links a:hover { color: var(--green); }

  @media (max-width: 1024px) {
    .prog-grid, .content-split { grid-template-columns: 1fr; gap: 40px; }
    .content-sidebar { order: 2; }
  }

  .mega-body { margin-bottom: 40px; }
  .mega-body p { margin-bottom: 24px; color: var(--text); line-height: 1.8; font-size: 1.05rem; }
  .mega-body h3 { margin: 40px 0 20px; color: var(--white); font-family: var(--serif); }

  .faq-accordion-mega { max-width: 900px; margin: 40px auto; display: flex; flex-direction: column; gap: 15px; }
  .faq-details-mega { background: var(--card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: all 0.3s ease; }
  .faq-details-mega:hover { border-color: var(--green-shimmer); }
  .faq-summary-mega { display: flex; align-items: center; justify-content: space-between; padding: 22px 28px; cursor: pointer; list-style: none; font-weight: 700; font-size: 1rem; color: var(--white); outline: none; }
  .faq-summary-mega::-webkit-details-marker { display: none; }
  .faq-q-text { flex: 1; padding-right: 20px; }
  .faq-icon { color: var(--green); font-size: 1.4rem; transition: transform 0.3s; }
  .faq-details-mega[open] .faq-icon { transform: rotate(45deg); }
  .faq-answer-mega { padding: 0 28px 25px; border-top: 1px solid var(--border); color: var(--text); font-size: 0.95rem; line-height: 1.7; }
  .faq-answer-mega p { margin-top: 15px; }
  .mb-12 { margin-bottom: 3rem; }
</style>
